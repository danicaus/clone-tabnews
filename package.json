{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Clone tabnews, desenvolvido durante o curso.dev do Filipe Deschamps",
  "main": "index.js",
  "scripts": {
    "predev": "npm run docker:up:dev && cross-env NODE_ENV=development npm run docker:wait:database && npm run migrations:up",
    "dev": "node infra/scripts/postdev-docker-stop.js",
    "pretest": "npm run docker:up:test",
    "test": "cross-env NODE_ENV=test concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "posttest": "npm run docker:stop:test",
    "pre:test:watch": "npm run docker:up:test && cross-env NODE_ENV=test next dev",
    "test:watch": "jest --runInBand --verbose --watchAll",
    "docker:up:test": "docker compose -f infra/compose.test.yaml up -d",
    "docker:stop:test": "docker compose -f infra/compose.test.yaml stop",
    "docker:down:test": "docker compose -f infra/compose.test.yaml down",
    "docker:up:dev": "docker compose -f infra/compose.yaml up -d",
    "docker:stop:dev": "docker compose -f infra/compose.yaml stop",
    "docker:down:dev": "docker compose -f infra/compose.yaml down",
    "docker:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "next lint --dir .",
    "prepare": "husky",
    "commit": "cz"
  },
  "author": "Daniela Caus",
  "license": "MIT",
  "dependencies": {
    "async-retry": "1.3.3",
    "bcryptjs": "3.0.2",
    "dotenv": "16.4.5",
    "dotenv-expand": "11.0.6",
    "next": "14.2.5",
    "next-connect": "1.0.0",
    "node-pg-migrate": "7.6.1",
    "pg": "8.12.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "swr": "2.2.5",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "19.4.0",
    "@commitlint/config-conventional": "19.2.2",
    "@faker-js/faker": "9.7.0",
    "commitizen": "4.3.0",
    "concurrently": "8.2.2",
    "cross-env": "7.0.3",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.5",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-jest": "28.8.0",
    "husky": "9.1.4",
    "jest": "29.7.0",
    "prettier": "3.3.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
